# ============================================================
# THVote 最小化环境变量配置
#
# 仅包含 Docker 运行时必需的环境变量
# 所有业务配置（数据库、JWT等）通过 Apollo 管理
# 敏感信息使用 Docker Secret
# ============================================================

# ==================== Apollo 配置中心 ====================
# Apollo 连接地址，容器启动前必须已知
APOLLO_META=http://apollo-config-prod:8081
APOLLO_ENV=prod
APOLLO_CLUSTER=default
APOLLO_APP_ID=thvote-backend

# ==================== 服务器配置 ====================
APP_HOST=0.0.0.0
APP_PORT=8000

# ==================== Docker Secret 配置 ====================
# 真正的敏感信息通过 Docker Secret 注入
# 使用方式: echo "password" | docker secret create thvote_db_password -
# ============================================================
