############################################################
# THVote FastAPI Backend - Example Environment Configuration
#
# Copy this file to `.env` and fill in real values for your
# local/dev/prod environments.
############################################################

# --- Database (choose ONE) ---
# This project uses SQLAlchemy async. You can point `DATABASE_URL` to:
#
# PostgreSQL (recommended for prod):
# - postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
# - postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
#
# MySQL (good for compatibility testing/local):
# - mysql://USER:PASSWORD@HOST:PORT/DB_NAME
# - mysql+asyncmy://USER:PASSWORD@HOST:PORT/DB_NAME
#
# SQLite (best for local debugging):
# - sqlite:///./local_db/dev.db
# - sqlite+aiosqlite:///./local_db/dev.db
#
# If you provide the non-async forms (`postgresql://`, `mysql://`, `sqlite:///`),
# the app will automatically normalize them to the async drivers.
DATABASE_URL=sqlite:///./local_db/dev.db

# Optional: SQLAlchemy engine echo (verbose SQL logging)
DATABASE_ECHO=false

# --- Redis (rate limiting, locks, cache) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT / Auth ---
# HS256 secret key or paths to ES256k key pair, depending on how you implement JWTs.
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=changeme-in-dev-only

# If you later want to mirror the original Rust ES256k setup, you can
# point these to PEM files and ignore JWT_SECRET_KEY.
JWT_PUBLIC_KEY_PATH=./keys/key-pub.pem
JWT_PRIVATE_KEY_PATH=./keys/key-priv.pem

# --- Vote Window Configuration (mirrors Rust config.toml semantics) ---
VOTE_YEAR=2024
VOTE_START_ISO=2024-01-01T00:00:00+00:00
VOTE_END_ISO=2024-12-31T23:59:59+00:00

# --- HTTP Server Binding ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Aliyun PNVS (SMS Authentication Service) ---
# Keep real values only in local `.env` or deployment secrets, never commit them.
ALIYUN_PNVS_ACCESS_KEY_ID=your_pnvs_access_key_id
ALIYUN_PNVS_ACCESS_KEY_SECRET=your_pnvs_access_key_secret
ALIYUN_PNVS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_PNVS_REGION_ID=cn-hangzhou
ALIYUN_PNVS_SCHEME_NAME=your_pnvs_scheme_name
ALIYUN_PNVS_SMS_SIGN_NAME=your_pnvs_sms_sign_name
ALIYUN_PNVS_SMS_TEMPLATE_CODE=your_pnvs_sms_template_code
ALIYUN_PNVS_CODE_LENGTH=6
ALIYUN_PNVS_VALID_TIME=300
ALIYUN_PNVS_INTERVAL=120

# --- Aliyun Direct Mail ---
# Prefer API-based sending. Keep credentials only in local `.env` or deployment secrets.
ALIYUN_DM_ACCESS_KEY_ID=your_dm_access_key_id
ALIYUN_DM_ACCESS_KEY_SECRET=your_dm_access_key_secret
ALIYUN_DM_ENDPOINT=dm.aliyuncs.com
ALIYUN_DM_REGION_ID=cn-hangzhou
ALIYUN_DM_ACCOUNT_NAME=no-reply@example.com
ALIYUN_DM_FROM_ALIAS=THVote
ALIYUN_DM_TAG_NAME=auth

# --- Aliyun Direct Mail SMTP (optional fallback) ---
ALIYUN_DM_SMTP_HOST=smtpdm.aliyun.com
ALIYUN_DM_SMTP_PORT=465
ALIYUN_DM_SMTP_USERNAME=your_smtp_username
ALIYUN_DM_SMTP_PASSWORD=your_smtp_password

# --- Bilibili Cookies (optional, for scraper development only) ---
# Keep real values only in local `.env`, never commit them.
BILIBILI_SESSDATA=your_bilibili_sessdata
BILIBILI_BILI_JCT=your_bilibili_csrf_token
BILIBILI_BUVID3=your_bilibili_buvid3
BILIBILI_B_NUT=your_bilibili_b_nut
BILIBILI_B_LSID=your_bilibili_b_lsid
BILIBILI_DEDEUSERID=your_bilibili_dedeuserid
