# ============================================================
# 测试环境环境变量
# ============================================================
# 复制此文件为 .env 并填写真实密码

# 数据库
POSTGRES_DB=thvote_test
POSTGRES_USER=thvote_test
POSTGRES_PASSWORD=your_test_db_password_here

# Redis
REDIS_URL=redis://redis:6379/0

# Apollo（测试环境默认启用，使用官方 MySQL 拓扑）
APOLLO_ENABLED=yes
# APOLLO_VERSION=2.4.0
# APOLLO_MYSQL_ROOT_PASSWORD=apollo_root_pass
# APOLLO_MYSQL_USER=apollo
# APOLLO_MYSQL_PASSWORD=apollo_pass
# APOLLO_META=http://apollo-configservice:8080
# APOLLO_ENV=fat
# APOLLO_CLUSTER=default
# APOLLO_APP_ID=thvote-backend
# APOLLO_NAMESPACES=application
# APOLLO_PORTAL_ENVS=fat
# APOLLO_PORTAL_META_SERVERS={"fat":"http://apollo-configservice:8080"}
# APOLLO_PORTAL_PORT=18080

# GraphQL schema 获取地址（前端 codegen 用）
# 不填则默认使用 http://backend:8000/graphql
# GRAPHQL_SCHEMA_URL=http://backend:8000/graphql

# JWT
JWT_SECRET_KEY=your_test_jwt_secret_here

# 投票配置
VOTE_YEAR=2026
VOTE_START_ISO=2026-01-01T00:00:00+08:00
VOTE_END_ISO=2026-12-31T23:59:59+08:00

# 镜像（CI 推送后覆盖）
BACKEND_IMAGE=ghcr.io/your-org/thvote-backend:test
VOTE_IMAGE=ghcr.io/your-org/thvote-vote:test
NAVIGATOR_IMAGE=ghcr.io/your-org/thvote-navigator:test
RESULT_IMAGE=ghcr.io/your-org/thvote-result:test
