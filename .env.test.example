# ============================================================
# 测试环境环境变量
# ============================================================
# 复制此文件为 .env 并填写真实密码

# 数据库
POSTGRES_DB=thvote_test
POSTGRES_USER=thvote_test
POSTGRES_PASSWORD=your_test_db_password_here

# Nacos 配置中心
NACOS_ENABLED=true
NACOS_SERVER_ADDRS=http://154.37.215.62:8848
NACOS_NAMESPACE=dfacd6e1-b442-476c-bffe-ff5504651c39
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=thvote_be
# Nacos 鉴权
NACOS_USERNAME=thvote_test
NACOS_PASSWORD=test_thV0te

# JWT
JWT_SECRET_KEY=your_test_jwt_secret_here
# session_token 有效期(天)。多久不活跃就要重新发验证码登录。默认 30。
# SESSION_EXPIRE_DAYS=30

# 投票配置
VOTE_YEAR=2026
VOTE_START_ISO=2026-01-01T00:00:00+08:00
VOTE_END_ISO=2026-12-31T23:59:59+08:00

# 镜像（CI 推送后覆盖）
BACKEND_IMAGE=ghcr.io/patchyvideo/thvote-backend:test

# ===============================================
# 本地开发覆盖配置
# ===============================================
# 如果你想在本地开发时禁用 Nacos 并使用本地配置，
# 将下面的注释去掉并设置 NACOS_ENABLED=false
# 然后填入你的本地配置值

# NACOS_ENABLED=false
# POSTGRES_PASSWORD=your_local_db_password
# NACOS_USERNAME=
# NACOS_PASSWORD=
