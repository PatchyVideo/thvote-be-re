# ============================================================
# THVote 测试环境配置文件
#
# 复制此文件为 .env.test 并填入实际值
# ============================================================

# ==================== 数据库配置 ====================
# 测试数据库密码（在 secrets 中设置）
TEST_DB_PASSWORD=your_secure_password_here

# ==================== Apollo 配置 ====================
# Apollo 数据库密码（在 secrets 中设置）
TEST_APOLLO_DB_PASSWORD=your_apollo_password_here

# Nacos 配置中心
NACOS_ENABLED=yes
NACOS_SERVER_ADDRS=http://nacos-server:8848
NACOS_NAMESPACE=test
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=thvote-be
# Nacos 鉴权（可选）
# NACOS_ACCESS_KEY=your_nacos_access_key
# NACOS_SECRET_KEY=your_nacos_secret_key

# ==================== JWT 配置 ====================
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256

# ==================== 投票配置 ====================
VOTE_YEAR=2025
VOTE_START_ISO=2025-01-01T00:00:00+08:00
VOTE_END_ISO=2025-12-31T23:59:59+08:00

# ==================== 服务配置 ====================
APP_HOST=0.0.0.0
APP_PORT=8000

# ==================== 外部服务（可选） ====================
# 阿里云短信
# ALIYUN_PNVS_ACCESS_KEY_ID=
# ALIYUN_PNVS_ACCESS_KEY_SECRET=
# ALIYUN_PNVS_ENDPOINT=
# ALIYUN_PNVS_REGION_ID=
# ALIYUN_PNVS_SMS_SIGN_NAME=
# ALIYUN_PNVS_SMS_TEMPLATE_CODE=

# 镜像（CI 推送后覆盖）
BACKEND_IMAGE=your-registry.cn-hangzhou.aliyuncs.com/your-namespace/toho-vote-be:test
VOTE_IMAGE=ghcr.io/your-org/thvote-vote:test
NAVIGATOR_IMAGE=ghcr.io/your-org/thvote-navigator:test
RESULT_IMAGE=ghcr.io/your-org/thvote-result:test
