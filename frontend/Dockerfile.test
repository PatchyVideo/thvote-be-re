# ============================================================
# THVote 测试环境前端 Dockerfile
#
# 基于主 Dockerfile，专门构建测试环境前端镜像
# ============================================================

FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9 --activate
WORKDIR /app

# ---- 克隆阶段 ----
FROM base AS cloner
ARG FRONTEND_BRANCH=dev
RUN apk add --no-cache git && \
    git clone --depth 1 --branch $FRONTEND_BRANCH https://github.com/PatchyVideo/Touhou-Vote.git /tmp/frontend

# ---- 构建阶段 ----
FROM base AS builder

# 复制整个前端仓库（确保所有依赖和脚本文件完整）
COPY --from=cloner /tmp/frontend /app

WORKDIR /app
RUN pnpm install && \
    pnpm --filter @touhou-vote/vote codegen && \
    pnpm --filter @touhou-vote/result codegen && \
    pnpm --filter @touhou-vote/vote build && \
    pnpm --filter @touhou-vote/result build

# ---- 最终阶段 ----
FROM nginx:alpine AS production
COPY --from=builder /app/packages/vote/dist /usr/share/nginx/html
COPY --from=builder /app/packages/result/dist /usr/share/nginx/html/result
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
