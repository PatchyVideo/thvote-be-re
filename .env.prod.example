# ============================================================
# 生产环境环境变量
# ============================================================
# 生产环境强烈建议使用 Docker Secrets 替代 env_file
# Docker Secret 用法：在 docker-compose.yml 中设置 environment.*_FILE
# 格式：POSTGRES_PASSWORD_FILE: /run/secrets/postgres_password
# 并在 secrets: 区定义文件来源

# 数据库
POSTGRES_DB=thvote_prod
POSTGRES_USER=thvote_prod
POSTGRES_PASSWORD=your_prod_db_password_here

# Redis
REDIS_URL=redis://redis:6379/0

# Apollo（生产环境推荐启用，使用官方 MySQL 拓扑）
APOLLO_ENABLED=yes
APOLLO_VERSION=2.4.0
APOLLO_MYSQL_ROOT_PASSWORD=your_apollo_root_password_here
APOLLO_MYSQL_USER=apollo
APOLLO_MYSQL_PASSWORD=your_apollo_db_password_here
APOLLO_META=http://apollo-configservice:8080
APOLLO_ENV=pro
APOLLO_CLUSTER=default
APOLLO_APP_ID=thvote-backend
APOLLO_NAMESPACES=application
APOLLO_PORTAL_ENVS=pro
APOLLO_PORTAL_META_SERVERS={"pro":"http://apollo-configservice:8080"}
APOLLO_PORTAL_PORT=8070

# JWT（强烈建议使用 Docker Secrets）
JWT_SECRET_KEY=your_prod_jwt_secret_here

# 投票配置
VOTE_YEAR=2026
VOTE_START_ISO=2026-01-01T00:00:00+08:00
VOTE_END_ISO=2026-12-31T23:59:59+08:00

# 镜像
BACKEND_IMAGE=ghcr.io/your-org/thvote-backend:prod
VOTE_IMAGE=ghcr.io/your-org/thvote-vote:prod
NAVIGATOR_IMAGE=ghcr.io/your-org/thvote-navigator:prod
RESULT_IMAGE=ghcr.io/your-org/thvote-result:prod
