# Nacos Configuration Center
# Documentation: https://nacos.io/docs/v2.3/guide/user/open-api/

# ===============================================
# Production/Sensitive Values (use GitHub Secrets)
# ===============================================
# NACOS_SERVER_ADDRS - Nacos 服务器地址
# NACOS_NAMESPACE - 命名空间 ID
# NACOS_USERNAME - Nacos 用户名
# NACOS_PASSWORD - Nacos 密码

# ===============================================
# Non-sensitive Defaults
# ===============================================

# Enable Nacos configuration center
NACOS_ENABLED=true

# Config group (default: DEFAULT_GROUP)
NACOS_GROUP=DEFAULT_GROUP

# Config data ID
NACOS_DATA_ID=thvote_be

# Logging
NACOS_LOG_LEVEL=INFO

# Request timeout (seconds)
NACOS_TIMEOUT_SECONDS=5

# ===============================================
# Local Development Override
# ===============================================
# To use local environment variables instead of Nacos,
# set NACOS_ENABLED=false in your local .env file
#
# Example local overrides:
# NACOS_ENABLED=false
# DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/thvote
# REDIS_HOST=localhost
# REDIS_PORT=6379
