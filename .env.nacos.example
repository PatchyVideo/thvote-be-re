# Nacos Configuration Center
# Documentation: https://nacos.io/docs/v2.3/guide/user/open-api/

# Enable Nacos configuration center
NACOS_ENABLED=true

# Nacos server addresses (comma-separated for multiple servers)
# Example: "192.168.1.1:8848,192.168.1.2:8848"
NACOS_SERVER_ADDRS=127.0.0.1:8848

# Namespace ID - your provided namespace
NACOS_NAMESPACE=ce2b18cc-e2ee-4673-a2a3-6b5b33309fb1

# Config group (default: DEFAULT_GROUP)
NACOS_GROUP=DEFAULT_GROUP

# Config data ID
NACOS_DATA_ID=thvote-be

# Authentication (choose one method):
# Method 1: Username/Password
# NACOS_USERNAME=nacos
# NACOS_PASSWORD=your_password

# Method 2: Access Key/Secret Key (for Aliyun RAM)
# NACOS_ACCESS_KEY=your_access_key
# NACOS_SECRET_KEY=your_secret_key

# Logging
NACOS_LOG_LEVEL=DEBUG

# Request timeout (seconds)
NACOS_TIMEOUT_SECONDS=5
